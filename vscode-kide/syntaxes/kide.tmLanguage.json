{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Program",
  "scopeName": "source.kide",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#identifiers"
    },
    {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.block.brace.kide",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "match": "\\b(?:context|dictionary|boundary|forbid|forbidden|aggregate|String|Int|Decimal|Boolean|Date|Timestamp|Void|command|invariant|bound|to|symbol|hash)\\b",
          "name": "keyword.control.kide"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "\\{|\\}|=>|:|\\(|,|\\)",
          "name": "keyword.operator.kide"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "match": "\"([^\"\\\\]|\\\\.)*\"",
          "name": "string.quoted.kide"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "[^{}]+",
          "name": "variable.other.kide"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*",
          "name": "variable.other.kide"
        }
      ]
    }
  }
}
