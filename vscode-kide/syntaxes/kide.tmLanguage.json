{
  "scopeName": "source.kide",
  "name": "Kide",
  "patterns": [
    {
      "match": "\\b(context|dictionary|boundary|aggregate|command|invariant|bound|to|symbol|hash|forbid|forbidden)\\b",
      "name": "keyword.control.kide"
    },
    {
      "match": "\"([^\"\\\\]|\\\\.)*\"",
      "name": "string.quoted.double.kide"
    },
    {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "entity.name.kide"
    }
  ]
}
