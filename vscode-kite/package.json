{
  "name": "kite-vscode",
  "displayName": "Kite",
  "description": "VS Code integration for Kite DSL with integrated LSP support.",
  "version": "0.1.0",
  "publisher": "kite",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kite",
        "aliases": [
          "Kite"
        ],
        "extensions": [
          ".kite"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kite",
        "scopeName": "source.kite",
        "path": "./syntaxes/kite.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Kite",
      "properties": {
        "kite.server.path": {
          "type": "string",
          "default": "kite",
          "description": "Path to the kite executable used to launch the language server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.95.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "typescript": "^5.7.2"
  }
}
